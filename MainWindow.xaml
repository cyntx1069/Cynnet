<Window
    x:Class="Cynnet.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Cynnet – 1.0 | Public">

    <Grid x:Name="RootGrid" Background="#0B0B10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#090910"
                BorderBrush="#20202A"
                BorderThickness="0,0,1,0"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#11111A"
                        BorderBrush="#2A2A36"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16"
                        Margin="0,0,0,14">
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="72"
                                Height="72"
                                Background="#11111A"
                                BorderBrush="#2A2A36"
                                BorderThickness="1"
                                CornerRadius="16">
                            <Grid Width="72" Height="72">
                                <TextBlock x:Name="AppLogoFallbackText"
                                           Text="C"
                                           Foreground="White"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <Image x:Name="AppLogoImage"
                                       Width="72"
                                       Height="72"
                                       Stretch="Uniform"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                            <TextBlock x:Name="AppBrandNameText"
                                       Text="Cynnet"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="AppHeaderVersionText"
                                       Text="1.0 | Public"
                                       Foreground="#9CA3AF"
                                       FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#11111A"
                        BorderBrush="#2A2A36"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="10">
                    <StackPanel Spacing="8">

                        <Button x:Name="ServerCreationTabButton"
                                Tag="ServerCreation"
                                Click="TabButton_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="#1B1B24"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <SymbolIcon Symbol="Home"/>
                                <TextBlock Text="Server Creation"
                                           FontSize="16"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="AddOnsTabButton"
                                Tag="AddOns"
                                Click="TabButton_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <SymbolIcon Symbol="AllApps"/>
                                <TextBlock Text="Add-Ons"
                                           FontSize="16"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="OtherTabButton"
                                Tag="Other"
                                Click="TabButton_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <SymbolIcon Symbol="More"/>
                                <TextBlock Text="Other"
                                           FontSize="16"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="OutputTabButton"
                                Tag="Output"
                                Click="TabButton_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <SymbolIcon Symbol="Message"/>
                                <TextBlock Text="Output"
                                           FontSize="16"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SettingsTabButton"
                                Tag="Settings"
                                Click="TabButton_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <SymbolIcon Symbol="Setting"/>
                                <TextBlock Text="Settings"
                                           FontSize="16"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Background="#11111A"
                        BorderBrush="#2A2A36"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Margin="0,14,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="AppReleaseNameText"
                                   Text="Public Release"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>

                        <TextBlock x:Name="AppVersionText"
                                   Text="Version 1.0"
                                   Foreground="#9CA3AF"
                                   FontSize="12"/>

                        <TextBlock x:Name="AppDescriptionText"
                                   Text="Minecraft server automation tool"
                                   Foreground="#9CA3AF"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#0B0B10">

            <ScrollViewer x:Name="ServerCreationPage">
                <StackPanel Padding="28" Spacing="18">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Server Creation"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Choose the server type, version, folder, and other settings."
                                   Foreground="#9CA3AF"/>
                    </StackPanel>

                    <Border Background="#11111A"
                            BorderBrush="#2A2A36"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Java status"
                                           Foreground="White"
                                           FontWeight="SemiBold"/>

                                <TextBlock x:Name="JavaStatusText"
                                           Text="Java check waiting..."
                                           Foreground="#9CA3AF"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button x:Name="CheckJavaButton"
                                    Grid.Column="1"
                                    Content="Check Java"
                                    Click="CheckJavaButton_Click"
                                    Padding="16,8"/>
                        </Grid>
                    </Border>

                    <Border Background="#11111A"
                            BorderBrush="#2A2A36"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <StackPanel Spacing="16">

                            <TextBlock Text="Server Settings"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <Grid ColumnSpacing="16" RowSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ComboBox x:Name="ServerTypeComboBox"
                                          Grid.Row="0"
                                          Grid.Column="0"
                                          Header="Server type"
                                          PlaceholderText="Select server type"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="ServerTypeComboBox_SelectionChanged"/>

                                <ComboBox x:Name="VersionComboBox"
                                          Grid.Row="0"
                                          Grid.Column="1"
                                          Header="Minecraft version"
                                          PlaceholderText="Select version"
                                          HorizontalAlignment="Stretch"
                                          MaxDropDownHeight="360"/>

                                <TextBox x:Name="ServerNameBox"
                                         Grid.Row="1"
                                         Grid.Column="0"
                                         Header="Server name"
                                         Text="MyMinecraftServer"
                                         PlaceholderText="Example: SurvivalServer"/>

                                <TextBox x:Name="MaxPlayersBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Header="Max players"
                                         Text="20"/>

                                <StackPanel Grid.Row="2"
                                            Grid.Column="0"
                                            Spacing="8">
                                    <TextBlock x:Name="RamLabel"
                                               Text="RAM: 4 GB"
                                               Foreground="White"/>

                                    <Slider x:Name="RamSlider"
                                            Minimum="1"
                                            Maximum="16"
                                            Value="4"
                                            StepFrequency="1"
                                            ValueChanged="RamSlider_ValueChanged"/>
                                </StackPanel>

                                <TextBox x:Name="PortBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Header="Server port"
                                         Text="25565"/>

                                <StackPanel Grid.Row="3"
                                            Grid.Column="0"
                                            Spacing="14">
                                    <ToggleSwitch x:Name="OnlineModeSwitch"
                                                  Header="Account mode"
                                                  IsOn="True"
                                                  OnContent="Premium accounts only"
                                                  OffContent="Offline"/>

                                    <ToggleSwitch x:Name="EulaSwitch"
                                                  Header="Minecraft EULA"
                                                  IsOn="False"
                                                  OnContent="Accepted"
                                                  OffContent="Not accepted"/>
                                </StackPanel>

                                <StackPanel Grid.Row="4"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Spacing="8">
                                    <TextBlock Text="Server folder location"
                                               Foreground="White"/>

                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="DestinationFolderBox"
                                                 Grid.Column="0"
                                                 PlaceholderText="Example: C:\Users\User\Desktop\Minecraft Server"/>

                                        <Button x:Name="BrowseDestinationButton"
                                                Grid.Column="1"
                                                Content="Browse"
                                                Click="BrowseDestinationButton_Click"
                                                Padding="16,8"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="AddOnsPage" Visibility="Collapsed">
                <StackPanel Padding="28" Spacing="18">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Add-Ons"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Select and download plugins or mods for your server."
                                   Foreground="#9CA3AF"/>
                    </StackPanel>

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#11111A"
                                BorderBrush="#2A2A36"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Plugins"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>

                                    <TextBlock x:Name="PluginStatusText"
                                               Text="Unavailable because Vanilla servers do not use plugins."
                                               Foreground="#9CA3AF"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <CheckBox x:Name="GeyserCheckBox"
                                          Content="Geyser - Bedrock crossplay"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="FloodgateCheckBox"
                                          Content="Floodgate - Bedrock without Java account"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="ViaVersionCheckBox"
                                          Content="ViaVersion - Version compatibility"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="LuckPermsCheckBox"
                                          Content="LuckPerms - Permissions system"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="EssentialsXCheckBox"
                                          Content="EssentialsX - Useful server commands"
                                          IsChecked="False"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#11111A"
                                BorderBrush="#2A2A36"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Mods"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>

                                    <TextBlock x:Name="ModStatusText"
                                               Text="Unavailable because Vanilla servers do not use mods."
                                               Foreground="#9CA3AF"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <CheckBox x:Name="LithiumCheckBox"
                                          Content="Lithium - Server optimization"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="FerriteCoreCheckBox"
                                          Content="FerriteCore - Memory optimization"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="SparkCheckBox"
                                          Content="Spark - Performance profiler"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="SimpleVoiceChatCheckBox"
                                          Content="Simple Voice Chat - Proximity voice chat"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="WorldEditModCheckBox"
                                          Content="WorldEdit - Building tools"
                                          IsChecked="False"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="OtherPage" Visibility="Collapsed">
                <StackPanel Padding="28" Spacing="18">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Other"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Optional features for the server."
                                   Foreground="#9CA3AF"/>
                    </StackPanel>

                    <Grid ColumnSpacing="18" RowSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#11111A"
                                BorderBrush="#2A2A36"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="playit.gg starter"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <CheckBox x:Name="PlayitCheckBox"
                                          Content="Create start_all.bat for playit.gg"
                                          IsChecked="False"/>

                                <TextBlock Text="Put playit.exe into your server folder to use Run Server + playit.gg."
                                           Foreground="#9CA3AF"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#11111A"
                                BorderBrush="#2A2A36"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Server Type Support"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="Vanilla, Paper, Fabric"
                                           Foreground="#D8C7FF"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="Spigot, Bukkit, and Forge coming soon!"
                                           Foreground="#9CA3AF"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="OutputPage" Visibility="Collapsed">
                <StackPanel Padding="28" Spacing="18">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Console"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <Border Background="#11111A"
                            BorderBrush="#2A2A36"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Actions"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <Grid ColumnSpacing="10" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="CreateServerButton"
                                        Grid.Column="0"
                                        Content="Create Server"
                                        Click="CreateServerButton_Click"
                                        Background="#6E00FF"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Padding="16,10"/>

                                <Button x:Name="OpenFolderButton"
                                        Grid.Column="1"
                                        Content="Open Folder"
                                        Click="OpenFolderButton_Click"
                                        IsEnabled="False"
                                        Padding="16,10"/>

                                <Button x:Name="RunServerButton"
                                        Grid.Column="2"
                                        Content="Run Server"
                                        Click="RunServerButton_Click"
                                        IsEnabled="False"
                                        Padding="16,10"/>

                                <Button x:Name="RunAllButton"
                                        Grid.Column="3"
                                        Content="Run Server + playit.gg"
                                        Click="RunAllButton_Click"
                                        IsEnabled="False"
                                        Padding="16,10"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#11111A"
                            BorderBrush="#2A2A36"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Console output"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <Button x:Name="ClearLogButton"
                                        Grid.Column="1"
                                        Content="Clear Log"
                                        Click="ClearLogButton_Click"
                                        Padding="14,7"/>
                            </Grid>

                            <TextBox x:Name="LogBox"
                                     FontFamily="Cascadia Mono"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     IsReadOnly="True"
                                     Height="430"
                                     Background="#050508"
                                     Foreground="#D1D5DB"
                                     BorderBrush="#2A2A36"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="SettingsPage" Visibility="Collapsed">
                <StackPanel Padding="28" Spacing="18">

                    <StackPanel Spacing="4">
                        <TextBlock Text="Settings"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"/>

                        <TextBlock Text="App preferences and customization."
                                   Foreground="#9CA3AF"/>
                    </StackPanel>

                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#11111A"
                                BorderBrush="#2A2A36"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Appearance"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <ToggleSwitch Header="Dark mode"
                                              IsOn="True"
                                              IsEnabled="False"
                                              OnContent="Enabled"
                                              OffContent="Disabled"/>

                                <ComboBox Header="Accent color"
                                          SelectedIndex="0"
                                          IsEnabled="False"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Purple"/>
                                    <ComboBoxItem Content="Blue"/>
                                    <ComboBoxItem Content="Green"/>
                                    <ComboBoxItem Content="Red"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="#11111A"
                                BorderBrush="#2A2A36"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Behavior"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>

                                <CheckBox x:Name="AutoCheckJavaCheckBox"
                                          Content="Check Java on startup"
                                          IsChecked="True"
                                          IsEnabled="True"/>

                                <CheckBox Content="Remember last settings"
                                          IsChecked="False"
                                          IsEnabled="False"/>

                                <CheckBox Content="Auto-open console after Create Server"
                                          IsChecked="False"
                                          IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>